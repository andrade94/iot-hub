APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# SECURITY: Set APP_DEBUG=false in production to prevent information disclosure
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# SECURITY: Set LOG_LEVEL=warning or LOG_LEVEL=error in production
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# SECURITY: Set SESSION_ENCRYPT=true in production to encrypt session data
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
FILESYSTEM_PRIVATE_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS / S3 Configuration
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_BUCKET_PRIVATE=
AWS_USE_PATH_STYLE_ENDPOINT=false

# File Storage Configuration
FILE_SIGNED_URL_EXPIRATION=60
FILE_MAX_SIZE_MB=10
FILE_OPTIMIZE_IMAGES=true
FILE_THUMBNAIL_WIDTH=300
FILE_THUMBNAIL_HEIGHT=300
FILE_THUMBNAIL_QUALITY=80
FILE_ORPHAN_CLEANUP_HOURS=24

# Broadcasting (Reverb)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=my-app-id
REVERB_APP_KEY=my-app-key
REVERB_APP_SECRET=my-app-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Frontend Broadcasting
VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Search
SCOUT_DRIVER=database

# ChirpStack MQTT (sensor data ingestion)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_AUTH_USERNAME=
MQTT_AUTH_PASSWORD=
MQTT_CLIENT_ID=astrea-iot-hub
MQTT_AUTO_RECONNECT_ENABLED=true
MQTT_AUTO_RECONNECT_MAX_RECONNECT_ATTEMPTS=10
MQTT_AUTO_RECONNECT_DELAY_BETWEEN_RECONNECT_ATTEMPTS=5

# ChirpStack REST API (device provisioning)
CHIRPSTACK_URL=https://cloud.chirpstack.io
CHIRPSTACK_API_KEY=
CHIRPSTACK_TENANT_ID=
# Device profile UUIDs (create in ChirpStack, paste IDs here)
CHIRPSTACK_PROFILE_EM300TH=
CHIRPSTACK_PROFILE_CT101=
CHIRPSTACK_PROFILE_WS301=
CHIRPSTACK_PROFILE_GS101=
CHIRPSTACK_PROFILE_AM307=
CHIRPSTACK_PROFILE_EM300PT=
CHIRPSTACK_PROFILE_EM310UDL=
